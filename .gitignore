# Project specific ignores
cookies.json
*.pkl

# Data directories (often too large for Git)
data/raw/*
data/processed/*
!data/raw/.gitkeep
!data/processed/.gitkeep

# Byte-compiled / optimized / DLL files
__pycache__/
*.py[cod]
*$py.class

# C extensions
*.so

# Jupyter Notebook
.ipynb_checkpoints

# Environments
.env
.venv
env/
venv/
ENV/

# Streamlit config and secrets
.streamlit/config.toml
.streamlit/secrets.toml

# OS metadata
.DS_Store
Thumbs.db
Desktop.ini

# Allow model artifacts and clean dataset for Streamlit Cloud deployment
!models/model.pkl
!models/tfidf.pkl
!data/processed/tweets_clean.csv